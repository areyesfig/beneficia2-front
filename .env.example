# Copia este archivo a .env y rellena solo en local. NO subas .env al repo.
# En producción usa EAS Secrets o variables de tu pipeline.

# URL del backend (obligatorio en producción)
EXPO_PUBLIC_API_URL=https://tu-api.ejemplo.com

# Solo desarrollo: host del backend en tu red local (opcional)
# EXPO_PUBLIC_DEV_API_HOST=192.168.1.100

# Solo desarrollo: user id para probar sin login (opcional). En producción el usuario viene del login.
# EXPO_PUBLIC_DEV_USER_ID=uuid-opcional
