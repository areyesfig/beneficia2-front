# Copia este archivo a .env: cp .env.example .env
# Rellena solo en local. NO subas .env al repo.
# En producción usa EAS Secrets o variables de tu pipeline.

# URL del backend (obligatorio en producción)
EXPO_PUBLIC_API_URL=https://tu-api.ejemplo.com

# --- Desarrollo: conectar con el backend local ---
# Android emulador: no hace falta (usa 10.0.2.2:3000 por defecto).
# iOS simulador o dispositivo físico: pon la IP de tu Mac en la red (ej. 192.168.1.10).
# EXPO_PUBLIC_DEV_API_HOST=192.168.1.10
# EXPO_PUBLIC_DEV_API_PORT=3000

# User id para probar sin login. Debe existir en el backend (ej. UUID de Profile).
# EXPO_PUBLIC_DEV_USER_ID=anonymous-dev
